{
  "realm": "apollo-sfs-realm",
  "displayName": "Apollo SFS",
  "enabled": true,
  "sslRequired": "external",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "verifyEmail": false,
  "editUsernameAllowed": true,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "accessTokenLifespan": 1800,
  "accessTokenLifespanForImplicitFlow": 1800,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 10,
  "smtpServer": {
    "host": "postfix",
    "port": "587",
    "from": "noreply@apollo-sfs.com",
    "fromDisplayName": "Apollo SFS",
    "replyTo": "",
    "replyToDisplayName": "",
    "envelopeFrom": "",
    "starttls": "true",
    "ssl": "false",
    "auth": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Application administrator \u2014 can manage users, send invitations, and view server metrics",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "apollo-sfs-api",
      "name": "Apollo SFS API",
      "description": "Confidential client used by the Go API for ROPC token exchange and Admin REST API access",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "<secret>",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "https://apollo-sfs.com/*"
      ],
      "webOrigins": [
        "https://apollo-sfs.com"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "1800",
        "use.refresh.tokens": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "lightweight.claim": "false"
          }
        },
        {
          "name": "audience mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "apollo-sfs-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50
    }
  ]
}