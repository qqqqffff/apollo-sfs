# Test-runner sidecar image.
# This image is NOT the production frontend — it runs the Jest test suite
# via test-server.js and is only included in development / staging compose files.
# It is never deployed to production.

FROM node:22-alpine

WORKDIR /app

# Install all deps (including devDependencies for Jest).
COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 9229

CMD ["node", "test-server.js"]
