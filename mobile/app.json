{
  "expo": {
    "name": "Apollo SFS",
    "slug": "apollo-sfs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apollosfs.app",
      "associatedDomains": ["applinks:apollo-sfs.com"],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Back up your photos and videos to Apollo SFS.",
        "NSPhotoLibraryAddUsageDescription": "Save downloaded files to your photo library."
      },
      "backgroundModes": ["fetch", "processing"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.apollosfs.app",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "apollo-sfs.com",
              "pathPrefix": "/register"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-media-library",
      [
        "expo-background-fetch",
        {}
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://apollo-sfs.com"
    }
  }
}
